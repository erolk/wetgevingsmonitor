# Kopieer naar .env.local voor lokale development, en zet ze in
# Vercel → Project → Settings → Environment Variables voor productie.

# --- Algemeen ---
# De publieke URL van de site (gebruikt in mail-links, zoals confirm-URLs).
# Op Vercel automatisch beschikbaar als VERCEL_URL — vul hier je eigen domein in.
NEXT_PUBLIC_SITE_URL=https://wetgevingsmonitor.nl

# --- Email versturen ---
# 'file' = schrijft mails naar data/outbox/ als .eml (alleen lokaal, niet op Vercel)
# 'resend' = stuurt echt via Resend API (productie)
EMAIL_MODE=file

# Afzenderadres in mails. Voor Resend moet dit een geverifieerd adres zijn
# op een gevalideerd domein (SPF/DKIM ingesteld).
EMAIL_FROM=Wetgevingsmonitor <noreply@example.invalid>

# API key van resend.com (alleen nodig als EMAIL_MODE=resend)
RESEND_API_KEY=

# --- Burger-uitleg genereren (optioneel) ---
# Alleen nodig als je 'npm run explain' draait om nieuwe uitleggen te maken.
# Niet nodig voor de site zelf — bestaande uitleggen staan in data/explanations.json.
ANTHROPIC_API_KEY=

# --- Beheer / admin-panel (/admin) ---
# Wachtwoord om in te loggen op /admin. Kies iets sterks en uniek.
ADMIN_PASSWORD=
# Geheime sleutel om het sessie-cookie te ondertekenen. Minstens 16 tekens,
# willekeurig. Genereer bijv. met:  openssl rand -hex 32
# Zonder ADMIN_PASSWORD én ADMIN_SESSION_SECRET blijft /admin volledig dicht.
ADMIN_SESSION_SECRET=
